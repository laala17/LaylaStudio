# Vercel Analytics (Optional)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# Deployment URL (set automatically on Vercel)
# NEXT_PUBLIC_DEPLOYMENT_URL=

# Aplikace URL pro odkazy v e-mailech (např. ověřovací odkaz)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend API klíč pro odesílání e-mailů
RESEND_API_KEY=your_resend_api_key_here

# =========================
# Supabase (Orders + Auth)
# =========================

# Pro lokální/DEV build:
# (Buď použij SUPABASE_URL, nebo NEXT_PUBLIC_SUPABASE_URL - v kódu je fallback)
SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co

# Service role key pro server-side zápisy do DB (registrace/login/reset + orders)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Publishable key (nepovinné, ale může se hodit pro klientské použití)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# =========================
# Stripe (Checkout + Webhooks)
# =========================

# Server-side secret key
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# Webhook signing secret (from Stripe dashboard, Webhook endpoint)
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
